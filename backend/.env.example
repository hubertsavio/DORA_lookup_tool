# Database Configuration
DATABASE_URL=sqlite:///dora_compliance.db
# For PostgreSQL: postgresql://user:password@localhost:5432/dora_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Search Index Directory
SEARCH_INDEX_DIR=search_index

# Scraper Configuration
SCRAPER_DELAY=2.0
SCRAPER_USER_AGENT=DORA-Compliance-Tool/1.0 (Educational/Research Purpose)

# Logging
LOG_LEVEL=INFO